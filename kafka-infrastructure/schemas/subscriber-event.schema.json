{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SubscriberEvent",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "eventId": { "type": "string" },
    "type": { "type": "string", "enum": ["SUBSCRIBED", "UNSUBSCRIBED"] },
    "subscriberId": { "type": "string" },
    "timestamp": { "type": "string", "format": "date-time" },
    "payload": { "type": "object" }
  },
  "required": ["eventId", "type", "subscriberId", "timestamp"]
}


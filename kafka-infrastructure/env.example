# Порты наружу
KAFKA_PORT=9092
SCHEMA_REGISTRY_PORT=8081

# Идентификатор окружения (для читаемости)
ENV_NAME=dev

# Kafka (KRaft, локальные дефолты)
# Для single-node оставляем 1. Для кластера задаются уникальные node.id на каждой ноде.
KAFKA_NODE_ID=1
# Cluster ID для KRaft (один и тот же для всех нод кластера).
# Если нужно сгенерировать новый: kafka-storage.sh random-uuid (на любой машине с Kafka tools).
KAFKA_KRAFT_CLUSTER_ID=abcdefghijklmnopqrstuv

# Объявляемый адрес для клиентов (PLAINTEXT_HOST).
# Прод / Swarm: укажите FQDN или IP (обязательно; не полагайтесь на localhost для внешних клиентов).
# Локально: в docker-compose можно не задавать — подставится localhost; для stack deploy значение обязательно.
KAFKA_ADVERTISED_HOST=

# Swarm/сервер (пример)
STACK_NAME=kafka

# Репликация и KRaft: сейчас single-node, позже — кластер без смены имён переменных.
# now: single
KAFKA_CONTROLLER_QUORUM_VOTERS=1@kafka:9093
KAFKA_DEFAULT_REPLICATION_FACTOR=1
KAFKA_MIN_INSYNC_REPLICAS=1
KAFKA_OFFSETS_TOPIC_REPLICATION_FACTOR=1
KAFKA_TRANSACTION_STATE_LOG_REPLICATION_FACTOR=1
KAFKA_TRANSACTION_STATE_LOG_MIN_ISR=1

# later (3 brokers): 1@kafka-1:9093,2@kafka-2:9093,3@kafka-3:9093

# Kafka UI (docker/kafka-ui/docker-compose.yml; после основного docker compose)
KAFKA_UI_PORT=8080
KAFKA_UI_CLUSTER_NAME=main
# Внутри сети kafka-infra (имена сервисов из docker-compose.yml)
KAFKA_BOOTSTRAP_SERVERS=kafka:29092
SCHEMA_REGISTRY_INTERNAL_URL=http://schema-registry:8081
KAFKA_UI_AUTH_TYPE=LOGIN_FORM
KAFKA_UI_ADMIN_USER=admin
KAFKA_UI_ADMIN_PASSWORD=changeme
